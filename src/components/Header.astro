---
import { localeUrl, type Locale } from "../lib/url";
import { BRAND } from "../i18n/ui";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<!-- Static header in normal document flow: brand link left, controls right.
     The flex row accepts future nav items between the two sides without
     restructuring; it renders no section links today. -->
<header class="flex items-center justify-between py-8">
  <a
    href={localeUrl(locale)}
    class="text-text hover:text-accent focus-visible:outline-accent text-sm font-semibold focus-visible:outline-2 focus-visible:outline-offset-2"
  >
    {BRAND}
  </a>
  <div class="flex items-center gap-2">
    <ThemeToggle locale={locale} />
    <LanguageSwitcher locale={locale} />
  </div>
</header>
