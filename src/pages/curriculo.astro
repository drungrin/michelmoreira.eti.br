---
// PT /curriculo, built as dist/curriculo.html and served at "/curriculo".
// Narrative intro + structured experience timeline + skills + education,
// sourced from the "resume" content collection (D-03). The timeline is
// custom markup, not Prose (UI-SPEC Role Assignment table). The counterpart
// page for this one is /en/resume (pagePairUrl, not the locale home). This
// same page is printed to PDF by the Plan 06 CI pipeline via @media print.
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Prose from "../components/Prose.astro";
import { pagePairUrl } from "../lib/pagePairs";
import { ui } from "../i18n/ui";

const entry = await getEntry("resume", "pt");
if (!entry)
  throw new Error('Missing content entry: collection "resume", id "pt"');
const { Content } = await render(entry);
const { experience, skills, education } = entry.data;
---

<BaseLayout
  locale="pt"
  counterpartPath={pagePairUrl("resume", "en")}
  pageTitle="Currículo · Michel Moreira"
  description="Currículo de Michel Moreira: mais de 20 anos em arquitetura de software, experiência, skills, formação e PDF para download."
>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      {entry.data.name}
    </h1>
    <p class="text-text-muted mt-2">{entry.data.title}</p>

    <a
      href="/michel-moreira-cv-pt.pdf"
      download
      class="text-accent no-print mt-4 inline-block"
    >
      {ui.pt.pdfDownloadLabel}
    </a>

    <Prose>
      <Content />
    </Prose>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Experiência</h2>
    <ol class="mt-4 flex flex-col gap-8">
      {
        experience.map((job) => (
          <li class="job-entry border-border border-b pb-8 last:border-0 last:pb-0">
            <h3 class="text-2xl font-semibold tracking-tight">
              {job.role}, {job.company}
            </h3>
            <p class="text-text-muted mt-1 text-sm">{job.period}</p>
            {job.note && (
              <p class="text-text-muted mt-1 text-sm italic">{job.note}</p>
            )}
            <ul class="achievements mt-4 flex list-disc flex-col gap-2 pl-5">
              {job.achievements.map((achievement) => (
                <li>{achievement}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Skills</h2>
    <div class="mt-4 flex flex-col gap-3">
      {
        skills.core.map((group) => (
          <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-4">
            <h3 class="text-text-muted shrink-0 text-sm font-semibold sm:w-44 sm:pt-0.5">
              {group.label}
            </h3>
            <p>{group.items.join(" · ")}</p>
          </div>
        ))
      }
    </div>
    <p class="text-text-muted mt-4 text-sm">
      <span class="font-semibold">Histórico:</span>
      {skills.historical.join(" · ")}
    </p>
    <p class="text-text-muted mt-2 text-sm">
      <span class="font-semibold">Idiomas:</span>
      {skills.languages.join(" · ")}
    </p>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Formação</h2>
    <ul class="mt-4 flex flex-col gap-2">
      {
        education.map((item) => (
          <li>
            {item.degree}, {item.institution}
            <span class="text-text-muted"> ({item.year})</span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
