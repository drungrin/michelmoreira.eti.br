---
// PT portfolio case detail, one route per "portfolioPt" entry, built as
// dist/portfolio/{slug}.html and served at "/portfolio/{slug}" (D-08). The
// counterpart is resolved by translationKey against the "portfolioEn"
// collection (never by slug/id, Pitfall 4) and passed as counterpartPath;
// a missing counterpart resolves to undefined and BaseLayout/LanguageSwitcher
// fall back to the locale home rather than erroring.
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import {
  portfolioCounterpartUrl,
  type PortfolioCounterpartEntry,
} from "../../lib/portfolioPairing";

export async function getStaticPaths() {
  const cases = await getCollection("portfolioPt");
  const enEntries: PortfolioCounterpartEntry[] = (
    await getCollection("portfolioEn")
  ).map((c) => ({ translationKey: c.data.translationKey, slug: c.id }));

  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, enEntries },
  }));
}

const { entry, enEntries } = Astro.props;
const { Content } = await render(entry);
const counterpartPath = portfolioCounterpartUrl(
  enEntries,
  entry.data.translationKey,
  "en",
);
---

<BaseLayout
  locale="pt"
  counterpartPath={counterpartPath}
  pageTitle={`${entry.data.title} · Michel Moreira`}
  description={entry.data.summary}
>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      {entry.data.title}
    </h1>
    <p class="text-text-muted mt-2 text-sm">
      {entry.data.period} · {entry.data.stack.join(", ")}
    </p>
    <Prose>
      <Content />
    </Prose>
  </section>
</BaseLayout>
