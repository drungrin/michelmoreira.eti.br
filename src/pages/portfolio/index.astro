---
// PT /portfolio, built as dist/portfolio.html and served at "/portfolio".
// Sober editorial list (D-08): entries sourced from the "portfolioPt"
// content collection, sorted by data.order. No cards, no thumbnails. The
// counterpart page for this one is /en/portfolio (pagePairUrl, not the
// locale home).
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pagePairUrl } from "../../lib/pagePairs";
import { localeUrl } from "../../lib/url";

const cases = (await getCollection("portfolioPt")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  locale="pt"
  counterpartPath={pagePairUrl("portfolio", "en")}
  pageTitle="Portfolio · Michel Moreira"
  description="Cases de arquitetura de Michel Moreira: modernização de batch legado em VB6 com IA e automação serverless com Amazon Bedrock."
>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Portfolio
    </h1>
    <ul class="mt-8 flex flex-col gap-8">
      {
        cases.map((item) => (
          <li>
            <a
              href={localeUrl("pt", "portfolio/" + item.id)}
              class="text-2xl font-semibold tracking-tight"
            >
              {item.data.title}
            </a>
            <p class="text-text-muted mt-2">{item.data.summary}</p>
            <p class="text-text-muted mt-1 text-sm">
              {item.data.period} · {item.data.stack.join(", ")}
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
