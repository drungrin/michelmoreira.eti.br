---
// PT home (root, default locale), built as dist/index.html and served at "/".
// Content renders inside the layout's main element; contact links live in the
// site footer. The counterpart page for this one is /en.
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="pt">
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Michel Moreira
    </h1>
    <p class="text-text-muted mt-2">Senior Software Architect</p>
    <p class="mt-4">
      20+ anos construindo software. Arquitetura, low-code e DevOps.
    </p>
  </section>
</BaseLayout>
