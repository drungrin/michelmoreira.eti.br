---
// PT home (root, default locale), built as dist/index.html and served at "/".
// Content renders inside the layout's main element; the CTA list below the
// hero links to the resume and portfolio pages (pagePairUrl) plus a direct
// mailto contact (D-11/D-16, no /contato page). The counterpart page for
// this one is /en.
import BaseLayout from "../layouts/BaseLayout.astro";
import { pagePairUrl } from "../lib/pagePairs";
import { ui } from "../i18n/ui";
---

<BaseLayout locale="pt">
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Michel Moreira
    </h1>
    <p class="text-text-muted mt-2">Senior Software Architect</p>
    <h2
      class="mt-6 text-xl font-semibold tracking-tight text-balance sm:text-2xl"
    >
      Transformo modernizações impossíveis em projetos executáveis.
    </h2>
    <p class="mt-4">
      Modernizo sistemas corporativos legados com engenharia de LLMs e agentes
      de IA. Projetos grandes demais para reescrever finalmente saem da gaveta.
      Recentemente migrei processos batch de VB6 para Java e Spring Batch com
      paridade funcional 1:1, preservando o comportamento do negócio.
    </p>
    <p class="mt-4">
      São mais de 20 anos executando a mesma tese de alavancagem tecnológica:
      co-criei plataformas low-code comerciais (Softwell Maker, Cronapp) e
      projetei sistemas de governo em IBM WebSphere atendendo todo o estado de
      Rondônia. Hoje uso IA para viabilizar evoluções que antes eram
      economicamente inviáveis.
    </p>
  </section>
  <section class="mt-12">
    <ul class="flex flex-col gap-8">
      <li>
        <a
          href={pagePairUrl("resume", "pt")}
          class="text-2xl font-semibold tracking-tight"
        >
          {ui.pt.ctaResumeTitle}
        </a>
        <p class="text-text-muted mt-2">{ui.pt.ctaResumeDesc}</p>
      </li>
      <li>
        <a
          href={pagePairUrl("portfolio", "pt")}
          class="text-2xl font-semibold tracking-tight"
        >
          {ui.pt.ctaPortfolioTitle}
        </a>
        <p class="text-text-muted mt-2">{ui.pt.ctaPortfolioDesc}</p>
      </li>
      <li>
        <a
          href="mailto:michel@michelmoreira.eti.br"
          class="text-2xl font-semibold tracking-tight"
        >
          {ui.pt.ctaContactTitle}
        </a>
        <p class="text-text-muted mt-2">{ui.pt.ctaContactDesc}</p>
      </li>
    </ul>
  </section>
</BaseLayout>
