---
// EN /en/resume, built as dist/en/resume.html and served at "/en/resume".
// Human-reviewed translation of the PT page, checked in the PR preview
// before merge. The counterpart page for this one is /curriculo
// (pagePairUrl, not the locale home). This same page is printed to PDF by
// the Plan 06 CI pipeline via @media print.
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import { pagePairUrl } from "../../lib/pagePairs";
import { ui } from "../../i18n/ui";

const entry = await getEntry("resume", "en");
if (!entry)
  throw new Error('Missing content entry: collection "resume", id "en"');
const { Content } = await render(entry);
const { experience, skills, education } = entry.data;
---

<BaseLayout
  locale="en"
  counterpartPath={pagePairUrl("resume", "pt")}
  pageTitle="Resume · Michel Moreira"
  description="Michel Moreira's resume: 20+ years in software architecture, experience, skills, education, and a PDF download."
>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      {entry.data.name}
    </h1>
    <p class="text-text-muted mt-2">{entry.data.title}</p>

    <a
      href="/michel-moreira-cv-en.pdf"
      download
      class="text-accent no-print mt-4 inline-block"
    >
      {ui.en.pdfDownloadLabel}
    </a>

    <Prose>
      <Content />
    </Prose>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Experience</h2>
    <ol class="mt-4 flex flex-col gap-8">
      {
        experience.map((job) => (
          <li class="job-entry border-border border-b pb-8 last:border-0 last:pb-0">
            <h3 class="text-2xl font-semibold tracking-tight">
              {job.role}, {job.company}
            </h3>
            <p class="text-text-muted mt-1 text-sm">{job.period}</p>
            <ul class="achievements mt-4 flex list-disc flex-col gap-2 pl-5">
              {job.achievements.map((achievement) => (
                <li>{achievement}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Skills</h2>
    <div class="mt-4 flex flex-col gap-3">
      {
        skills.core.map((group) => (
          <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-4">
            <h3 class="text-text-muted shrink-0 text-sm font-semibold sm:w-44 sm:pt-0.5">
              {group.label}
            </h3>
            <p>{group.items.join(" · ")}</p>
          </div>
        ))
      }
    </div>
    <p class="text-text-muted mt-4 text-sm">
      <span class="font-semibold">Historical:</span>
      {skills.historical.join(" · ")}
    </p>
    <p class="text-text-muted mt-2 text-sm">
      <span class="font-semibold">Languages:</span>
      {skills.languages.join(" · ")}
    </p>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight">Education</h2>
    <ul class="mt-4 flex flex-col gap-2">
      {
        education.map((item) => (
          <li>
            {item.degree}, {item.institution}
            <span class="text-text-muted"> ({item.year})</span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
