---
// EN home, built as dist/en.html and served at "/en" (no trailing slash, the
// canonical form). Structure mirrors the PT page: hero, then a typographic
// Selected Work list from the portfolioEn collection (result line before stack),
// closing on a single accent CTA. The EN copy is a draft, reviewed in the PR
// preview before merge; contact links live site-wide in Footer.astro and are not
// repeated here (D-03). Counterpart page: /.
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localeUrl } from "../../lib/url";
import { pagePairUrl } from "../../lib/pagePairs";
import { sortCasesByOrder, formatCaseNumber } from "../../lib/caseDisplay";
import { ui } from "../../i18n/ui";

const cases = sortCasesByOrder(await getCollection("portfolioEn"));
---

<BaseLayout locale="en">
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Michel Moreira
    </h1>
    <p class="text-text-muted mt-2">Senior Software Architect</p>
    <p class="mt-6 max-w-2xl">
      I turn modernizations that once looked unfeasible into deliverable
      projects. I modernize legacy enterprise systems with LLM and AI-agent
      engineering. Recently I migrated VB6 batch processes to Java and Spring
      Batch with 1:1 functional parity, preserving the business behavior.
    </p>
    <p class="mt-4 max-w-2xl">
      For more than twenty years I have run the same thesis of technological
      leverage: I co-created the low-code platforms Softwell Maker and Cronapp
      and designed government systems on IBM WebSphere used across the entire
      state of Rondônia. Today I apply AI to make modernizations viable that
      used not to pay for themselves.
    </p>
  </section>

  <section class="mt-16">
    <h2 class="text-text-muted/70 text-sm tracking-wide uppercase">
      {ui.en.selectedWorkLabel}
    </h2>
    <ul class="mt-6 flex flex-col">
      {
        cases.map((item, index) => (
          <li class="border-border border-b py-6">
            <div class="flex items-baseline gap-3">
              <span class="text-text-muted/70 font-mono text-sm">
                {formatCaseNumber(index)}
              </span>
              <h3 class="text-lg font-semibold tracking-tight">
                {item.data.title}
              </h3>
            </div>
            <p class="text-text-muted mt-2">{item.data.result}</p>
            <p class="text-text-muted mt-1 font-mono text-xs wrap-break-word">
              {item.data.stackHighlights.join(", ")}
            </p>
            <a
              href={localeUrl("en", "portfolio/" + item.id)}
              class="text-accent mt-3 inline-block"
            >
              {ui.en.readCaseLabel}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-12">
    <a
      href={pagePairUrl("portfolio", "en")}
      class="text-accent text-2xl font-semibold tracking-tight"
    >
      {ui.en.viewAllCasesLabel}
    </a>
  </section>
</BaseLayout>
