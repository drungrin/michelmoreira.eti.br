---
// EN /en/portfolio, built as dist/en/portfolio.html and served at
// "/en/portfolio". Human-reviewed translation of the PT page, checked in
// the PR preview before merge. The counterpart page for this one is
// /portfolio (pagePairUrl, not the locale home).
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pagePairUrl } from "../../../lib/pagePairs";
import { localeUrl } from "../../../lib/url";

const cases = (await getCollection("portfolioEn")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout locale="en" counterpartPath={pagePairUrl("portfolio", "pt")}>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Portfolio
    </h1>
    <ul class="mt-8 flex flex-col gap-8">
      {
        cases.map((item) => (
          <li>
            <a
              href={localeUrl("en", "portfolio/" + item.id)}
              class="text-2xl font-semibold tracking-tight"
            >
              {item.data.title}
            </a>
            <p class="text-text-muted mt-2">{item.data.summary}</p>
            <p class="text-text-muted mt-1 text-sm">
              {item.data.period} · {item.data.stack.join(", ")}
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
