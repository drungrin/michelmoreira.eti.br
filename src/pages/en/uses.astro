---
// EN /en/uses, built as dist/en/uses.html and served at "/en/uses". Human-
// reviewed translation of the PT page, checked in the PR preview before
// merge. The counterpart page for this one is /uses (pagePairUrl, not the
// locale home).
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import { pagePairUrl } from "../../lib/pagePairs";

const entry = await getEntry("uses", "en");
if (!entry)
  throw new Error('Missing content entry: collection "uses", id "en"');
const { Content } = await render(entry);
---

<BaseLayout
  locale="en"
  counterpartPath={pagePairUrl("uses", "pt")}
  pageTitle="Uses · Michel Moreira"
  description="Michel Moreira's setup: workstation, notebook, homelab, and day-to-day tools."
>
  <section class="mt-12">
    <h1 class="text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl">
      Uses
    </h1>
    <Prose>
      <Content />
    </Prose>
  </section>
</BaseLayout>
